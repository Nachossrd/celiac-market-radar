# Copia este archivo a `.env` y ajusta los valores. `.env` no se versiona.

PORT=3000

# Region activa del motor. Al cambiar este valor y guardar, el region-watcher
# dispara automaticamente la pipeline (INE + census + celiac + export).
# Opciones: metropolitana, valparaiso, biobio, antofagasta, coquimbo
REGION=metropolitana

# Para desactivar el watcher (solo arranque manual): WATCHER=off
# WATCHER=off

# Delays (ms) entre requests para no ser bloqueado por los sitios scrapeados.
DELAY_GOOGLE_MS=8000
DELAY_MERCADOLIBRE_MS=3000
DELAY_SUPERMERCADO_MS=2000
DELAY_RAPPI_MS=2000

# SerpAPI (opcional) — deja vacio si no lo usas.
SERPAPI_KEY=

# Proxy residencial (opcional) — deja vacio si no lo usas.
PROXY_URL=
